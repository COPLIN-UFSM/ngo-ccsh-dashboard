	column 'Dia atual'
		lineageTag: db5bd9de-54ac-4d06-8584-228b03954481
		summarizeBy: none
		isNameInferred
		sourceColumn: [Dia atual]

		annotation SummarizationSetBy = Automatic

	partition dCalendario = calculated
		mode: import
		source =
				ADDCOLUMNS (
				    CALENDARAUTO(),
				    "Ano", YEAR ( [Date] ),
				    "Mês num", MONTH ( [Date] ),
				    "Mês nome", FORMAT ( [Date], "[$-pt-BR]mmmm" ),
				    "Dia", DAY ( [Date] ),
				    "Ano atual", IF ( YEAR ( [Date] ) = YEAR ( TODAY () ), "S", "N" ),
				    "Mês atual",
				        IF (
				            YEAR ( [Date] ) = YEAR ( TODAY () )
				                && MONTH ( [Date] ) = MONTH ( TODAY () ),
				            "S",
				            "N"
				        ),
				    "Dia atual",
				        IF (
				            YEAR ( [Date] ) = YEAR ( TODAY () )
				                && MONTH ( [Date] ) = MONTH ( TODAY () )
				                && DAY ( [Date] ) = DAY ( TODAY () ),
				            "S",
				            "N"
				        )
				)

	annotation PBI_Id = cc8c282432de47f4bdd228e0cb61ac03

