        "measures": [
          {
            "name": "Débitos totais",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Débito\"",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "1bbf3f09-a786-48cd-a867-ffe7073d7b57"
          },
          {
            "name": "Créditos totais",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Crédito\"",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "9366692b-92ee-4e1b-9e7f-9eb20972b685"
          },
          {
            "name": "Créditos IDR",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Crédito\",",
              "    FILTER(",
              "        'Transações',",
              "        'Transações'[Finalidade] = \"IDR - Custeio\" || 'Transações'[Finalidade] = \"IDR - Capital\"",
              "    )",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "63e86dae-bb4e-4cd2-8dd8-8de48d5d01a3"
          },
          {
            "name": "Créditos transferências",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Crédito\",",
              "    FILTER(",
              "        'Transações',",
              "        ('Transações'[Finalidade] = \"Transferência - Custeio\") || ('Transações'[Finalidade] = \"Transferência - Capital\")",
              "    )",
              ")"
            ],
            "lineageTag": "ca34cedf-04ae-4757-9391-c42bb7569342"
          },
          {
            "name": "Débitos transferências",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Débito\",",
              "    ('Transações'[Finalidade] = \"Transferência - Custeio\") || ('Transações'[Finalidade] = \"Transferência - Capital\")",
              ")"
            ],
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "cb9f292d-9ea0-4b74-81ce-8b520f2d3843"
          },
          {
            "name": "Débitos totais a pagar",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Débito\",",
              "    'Transações'[Pago] = FALSE",
              ")"
            ],
            "lineageTag": "ac25965d-99fe-4798-935f-56b964296bf6"
          },
          {
            "name": "Débitos totais pagos",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    SUM('Transações'[Montante]),",
              "    'Transações'[Tipo] = \"Débito\",",
              "    'Transações'[Pago] = TRUE",
              ")"
            ],
            "lineageTag": "dbdeebfa-2935-4423-b61a-ca3f29f34d1e"
          }
        ],
